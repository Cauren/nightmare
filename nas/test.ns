* CPU bootstrap segment

lib		seg	"library.so"
_root		seg	0
_alias		seg	_root

Téµl		equ	1234

		seg	_root
		org	0

trapmap		da	reset_vec
		da	fault_vec
		da	berr_vec
		da	ill_vec
		da	nan_vec
		da	nmi_vec

		org	@1000
segmap		dl	0		; SEG0 -> whole memory
		dl	640*1024	; 640k ought to be enough for anyone.  :-)
		dw	@17, 0		; super, rwx
		dl	0

		dl	trapmap		; SEG1 -> vector space
		dl	@1000
		dw	@03, 0		; super, r
		dl	0

		dl	segmap		; SEG2 -> segment map
		dl	@1000
		dw	@07, 0		; super, rw
		dl	0

		org	_root:@2000

seg_used	dw	3
seg_free	dw	0
		dw	-1

reset_vec	db	1,2,"three",4,5,6,7
		mov	#12,d0
		mov	#@1000,d1
		mov	#symbol.w,d2
		mov	d3,segmap
		jsr	lib:function
symbol		equ	.-reset_vec
		lda	_root:segmap,a3
		add	a3:4,d1
		lds	trapmap,a0
		add	d0,(a1)
		add	d1.w,d0
		sub	(a3)+.b,d2
		dec	-(a4)
		clr	(-2,a1).b
		clr	([5,a1])
		clr	(6,a1,d2*2).w
		clr	([7,a1,d3*4])
		clr	([7,a2,d4],9)
		clr	([4,pc])
		trap	#2
		push	d0,d1,d2,d3,a5,a6,ccr
